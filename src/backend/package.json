{
  "name": "unigo-backend",
  "version": "1.0.0",
  "description": "RESTful API for Mon Nho Handmade (Unigo) - Handmade Products E-commerce",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "cross-env NODE_ENV=production node src/index.js",
    "dev": "cross-env NODE_ENV=development nodemon src/index.js",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "start:migrate": "npm run db:migrate && npm start"
  },
  "keywords": [
    "handmade",
    "ecommerce",
    "api",
    "express",
    "postgresql"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.0",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "zod": "^4.3.6",
    "cross-env": "^7.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "nodemon": "^3.0.2",
    "prisma": "^5.22.0"
  },
  "engines": {
    "node": ">=20.17.0 <21"
  }
}
