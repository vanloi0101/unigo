# ==================== DATABASE ====================
# Chuỗi kết nối PostgreSQL
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?schema=public
# - user: Tên user PostgreSQL (mặc định: postgres)
# - password: Mật khẩu của user PostgreSQL
# - host: Địa chỉ server (mặc định: localhost cho local)
# - port: Port PostgreSQL (mặc định: 5432)
# - database: Tên database (phải tạo trước bằng SQL CREATE DATABASE)
# - schema: Schema tư nhân (mặc định: public)
DATABASE_URL="postgresql://user:12345678@localhost:5432/unigo_db?schema=public"

# ==================== SERVER ====================
# Port mà Express server sẽ chạy
# Kiểm tra port có sẵn trước khi đổi
PORT=5000

# Môi trường chạy (development = log chi tiết, production = log tối thiểu)
# Giá trị: development | production | test
NODE_ENV=development

# ==================== AUTHENTICATION ====================
# Secret key cho JWT token
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# Thời hạn token (vd: 7d, 24h, 30d)
JWT_EXPIRE=7d

# ==================== CORS ====================
# Địa chỉ frontend được phép gọi API
CORS_ORIGIN=http://localhost:5173

# ==================== CLOUDINARY ====================
# Cloudinary configuration for image upload
# Lấy từ https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret


# ==================== JWT (JSON Web Token) ====================
# Secret key để ký và xác minh JWT tokens
# ⚠️ NGUY HIỂM: Giữ bí mật, không public lên GitHub
# Thay đổi giá trị này để bảo mật cao hơn (tối thiểu 32 ký tự)
JWT_SECRET=your_jwt_secret_key_here_change_me_in_production

# Thời gian token hết hạn
# Giá trị: 7d (7 ngày), 24h (24 giờ), 1h (1 giờ), v.v...
JWT_EXPIRE=7d

# ==================== CORS (Cross-Origin Resource Sharing) ====================
# Địa chỉ frontend được phép gửi request tới API này
# Mặc định: http://localhost:5173 (Vite port mặc định)
# Để cho phép nhiều origin: http://localhost:3000,http://localhost:5173
# Để cho phép tất cả origins (KHÔNG AN TOÀN): *
CORS_ORIGIN=http://localhost:5173
