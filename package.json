{
  "name": "unigo-backend",
  "version": "1.0.0",
  "description": "RESTful API for Unigo Handmade E-commerce",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "cross-env NODE_ENV=production node src/index.js",
    "dev": "cross-env NODE_ENV=development nodemon src/index.js",
    "db:migrate": "cross-env NODE_ENV=production npx prisma migrate deploy",
    "start:migrate": "npm run db:migrate && npm start"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.6",
    "helmet": "^8.1.0",
    "express-rate-limit": "^8.4.1",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "multer": "^1.4.5-lts.1",
    "cloudinary": "^1.41.0",
    "zod": "^4.3.6",
    "@prisma/client": "^5.22.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "prisma": "^5.22.0",
    "cross-env": "^7.0.3"
  }
}